# ── Secrets ───────────────────────────────────────────────
# NEVER commit the .env file — it contains your email password
backend/.env

# ── Python cache files ────────────────────────────────────
# Auto-generated by Python, not needed in version control
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Node.js ───────────────────────────────────────────────
# The node_modules folder is huge (~200MB). Don't commit it.
# Anyone who clones the repo just runs `npm install` to get it back.
frontend/node_modules/

# ── macOS system files ────────────────────────────────────
.DS_Store

# ── Virtual environments ──────────────────────────────────
venv/
.venv/
env/
