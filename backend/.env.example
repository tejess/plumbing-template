# ════════════════════════════════════════════════════════
# Apex Plumbing Co. — Environment Variables
# ════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values.
# The .env file is NEVER committed to version control —
# it contains secrets that must stay private.
#
# HOW TO USE:
#   cp .env.example .env
#   Then edit .env with your actual credentials.
# ════════════════════════════════════════════════════════

# Flask app entry point — required for `flask run`
FLASK_APP=app.py
FLASK_ENV=development

# Flask secret key — any random string, keep it private
SECRET_KEY=change-this-to-any-random-string

# ── Email (SMTP) Settings ────────────────────────────────
# For Gmail, use smtp.gmail.com and port 587.
# You MUST use an "App Password" — not your real Gmail password.
# To generate one: Google Account → Security → 2-Step Verification → App Passwords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-character-app-password

# The email address that receives contact/quote form submissions
# (can be the same as MAIL_USERNAME)
RECIPIENT_EMAIL=your-email@gmail.com

# ── Jobber API ───────────────────────────────────────────
# Generate an access token from your Jobber developer app
JOBBER_ACCESS_TOKEN=your-jobber-access-token
JOBBER_API_VERSION=2025-04-16
